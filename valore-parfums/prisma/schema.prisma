generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Perfume / Inventory ───────────────────────────────
model Perfume {
  id                String   @id @default(uuid())
  name              String
  brand             String   @default("")
  inspiredBy        String   @default("")
  description       String   @default("")
  category          String   @default("Unisex")
  season            String   @default("")
  images            String   @default("[]") // JSON array of image URLs
  marketPricePerMl  Float    @default(0)
  purchasePricePerMl Float   @default(0)  // cost price you bought it for
  totalStockMl      Float    @default(0)
  lowStockThreshold Float    @default(20)
  isActive          Boolean  @default(true)
  isBestSeller      Boolean  @default(false)
  owner             String   @default("Store") // Store | Tayeb | Enid
  isPersonalCollection Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orderItems    OrderItem[]
  stockRequests StockRequest[]
  wishlists     Wishlist[]
}

// ─── Decant Sizes ──────────────────────────────────────
model DecantSize {
  id        String   @id @default(uuid())
  ml        Float    @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─── Bottle Inventory ──────────────────────────────────
model BottleInventory {
  id              String   @id @default(uuid())
  ml              Float    @unique
  costPerBottle   Float    @default(0)
  availableCount  Int      @default(0)
  lowStockThreshold Int    @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── System Settings ───────────────────────────────────
model Settings {
  id              String  @id @default("default")
  profitMargin    Float   @default(20)
  packagingCost   Float   @default(20)
  platformFees    Float   @default(0)
  tierMargins     String  @default("{\"Budget\":{\"3\":37,\"5\":37,\"6\":37,\"10\":27,\"15\":22,\"30\":17},\"Premium\":{\"3\":32,\"5\":32,\"6\":32,\"10\":22,\"15\":17,\"30\":12},\"Luxury\":{\"3\":45,\"5\":45,\"6\":45,\"10\":35,\"15\":27,\"30\":27}}")
  currency        String  @default("BDT")
  lowStockAlertMl Float   @default(20)
  owner1Name      String  @default("Tayeb")
  owner2Name      String  @default("Enid")
  owner1Share     Float   @default(60)
  owner2Share     Float   @default(40)
}

// ─── Bulk Pricing Rules ────────────────────────────────
model BulkPricingRule {
  id             String  @id @default(uuid())
  minQuantity    Int     @default(2)
  discountPercent Float  @default(0)
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
}

// ─── Orders ────────────────────────────────────────────
model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String
  customerEmail String      @default("")
  pickupMethod  String      @default("Pickup")  // Pickup or Delivery
  status        String      @default("Pending")  // Pending, Confirmed, Ready, Completed, Cancelled
  voucherCode   String?
  discount      Float       @default(0)
  subtotal      Float       @default(0)
  total         Float       @default(0)
  profit        Float       @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  perfumeId   String
  perfumeName String
  ml          Float
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  costPrice   Float   @default(0) // buying price for profit calc
  ownerName   String  @default("Store") // Store | Tayeb | Enid
  ownerProfit Float   @default(0)
  platformProfit Float @default(0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  perfume Perfume @relation(fields: [perfumeId], references: [id])
}

// ─── Vouchers ──────────────────────────────────────────
model Voucher {
  id            String    @id @default(uuid())
  code          String    @unique
  discountType  String    @default("percentage") // percentage | fixed
  discountValue Float     @default(0)
  minOrderValue Float     @default(0)
  usageLimit    Int       @default(100)
  usedCount     Int       @default(0)
  firstOrderOnly Boolean  @default(false)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

// ─── Stock Requests ────────────────────────────────────
model StockRequest {
  id          String   @id @default(uuid())
  perfumeId   String
  perfumeName String
  customerName  String
  customerPhone String
  desiredMl   Float
  quantity    Int      @default(1)
  status      String   @default("Pending") // Pending, Fulfilled, Declined
  createdAt   DateTime @default(now())

  perfume Perfume @relation(fields: [perfumeId], references: [id])
}

// ─── Users (Auth) ──────────────────────────────────────
model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String    @default("")
  passwordHash String
  role         String    @default("customer") // customer | admin
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wishlists Wishlist[]
}

// ─── Wishlist ──────────────────────────────────────────
model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  perfumeId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  perfume Perfume @relation(fields: [perfumeId], references: [id], onDelete: Cascade)

  @@unique([userId, perfumeId])
}

// ─── Notifications (Announcement Bar) ──────────────────
model Notification {
  id        String   @id @default(uuid())
  message   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
